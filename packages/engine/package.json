{
  "name": "@botc/engine",
  "version": "0.1.0",
  "description": "Blood on the Clocktower game engine — pure rules, no I/O",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npx tsc && npx tsc -p tsconfig.esm.json",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"]
  }
}
