{
  "name": "@botc/server",
  "version": "0.1.0",
  "description": "Blood on the Clocktower — game server (Fastify + WebSocket)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "ts-node src/index.ts",
    "pretest": "tsc -b ../engine",
    "test": "jest --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@botc/engine": "*",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
